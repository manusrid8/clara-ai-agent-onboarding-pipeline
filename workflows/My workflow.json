      "parameters": {
        "jsCode": "return $input.all().map(item => {\n\nconst transcript = item.json.transcript;\n\nlet company = \"Unknown Company\";\n\nif(transcript.includes(\"Plumbing\")) company = \"ABC Plumbing\";\nif(transcript.includes(\"Electric\")) company = \"Elite Electric\";\nif(transcript.includes(\"HVAC\")) company = \"Quick HVAC\";\nif(transcript.includes(\"Cleaning\")) company = \"Bright Cleaning\";\nif(transcript.includes(\"Landscaping\")) company = \"Prime Landscaping\";\n\nconst memo = {\n  account_id: item.json.account_id,\n\n  company_name: company,\n\n  business_hours: {\n    days: [\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\n    start: \"09:00\",\n    end: \"17:00\"\n  },\n\n  services_supported: [],\n  emergency_definition: []\n};\n\nreturn { json: memo };\n\n});"
      },
